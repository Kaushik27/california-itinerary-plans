.DS_Store

# Dependencies and package-manager cache
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Local environment and secrets
.env
.env.*
*.pem

# Generated app output
dist/
.vinext/
.wrangler/
coverage/
out/
.next/
work/
outputs/

# Local QA artifacts that are useful during design review but not needed to clone/run
qa-comparison/
*/qa/
*/design-qa.md

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
